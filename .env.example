# =============================================================================
# AI-Based Answer Script Evaluation System
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Connection (Required)
# -----------------------------------------------------------------------------
# For local development:
# MONGO_URI=mongodb://localhost:27017/
#
# For MongoDB Atlas (recommended for production/Colab):
# MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
#
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=answer_evaluation_system

# -----------------------------------------------------------------------------
# JWT Authentication (Required)
# -----------------------------------------------------------------------------
# IMPORTANT: Change this to a strong random secret in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
#
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ACCESS_TOKEN_EXPIRES=86400

# -----------------------------------------------------------------------------
# Flask Settings
# -----------------------------------------------------------------------------
# Development: FLASK_DEBUG=1
# Production (Render/Colab): FLASK_DEBUG=0
#
FLASK_DEBUG=1

# -----------------------------------------------------------------------------
# Upload Settings
# -----------------------------------------------------------------------------
# Max file upload size in bytes (8MB = 8388608)
MAX_CONTENT_LENGTH=8388608

# -----------------------------------------------------------------------------
# Memory Limits (For Render Free Tier - 512MB RAM)
# -----------------------------------------------------------------------------
# Limit concurrent evaluations to prevent memory exhaustion
MAX_CONCURRENT_EVALUATIONS=1

# Limit PDF pages to process (each page uses ~20-50MB RAM)
MAX_PDF_PAGES=10

# -----------------------------------------------------------------------------
# Render-Specific (Auto-set by Render, don't change)
# -----------------------------------------------------------------------------
# RENDER=true
# PORT=10000

# -----------------------------------------------------------------------------
# ngrok Tunnel (For public access from Colab / local dev)
# -----------------------------------------------------------------------------
# Get your free auth token at: https://dashboard.ngrok.com/get-started/your-authtoken
# Required only if using start_with_ngrok.py or Google Colab
NGROK_AUTH_TOKEN=your-ngrok-auth-token-here
